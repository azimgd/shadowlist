{
  "name": "shadowlist-utils",
  "version": "0.1.0",
  "description": "Shared, platform-agnostic helpers and demo data generators for the shadowlist examples (RN + WASM).",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./native": {
      "types": "./src/native/index.ts",
      "react-native": "./src/native/index.ts",
      "default": "./src/native/index.ts"
    },
    "./web": {
      "types": "./src/web/index.ts",
      "default": "./src/web/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*",
    "shadowlist": "*",
    "shadowlist-wasm": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-safe-area-context": {
      "optional": true
    },
    "shadowlist": {
      "optional": true
    },
    "shadowlist-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
